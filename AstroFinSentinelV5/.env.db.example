# AstroFin V5 - Database Configuration
# Copy to .env and fill in your values

# PostgreSQL (TimescaleDB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=astrofin
DB_USER=astrofin
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# LangGraph State Store
LANGGRAPH_POSTGRES=postgresql://astrofin:your_secure_password_here@localhost:5432/astrofin

# Optional: TimescaleDB license (for production)
# TIMESCALEDB_LICENSE=community
