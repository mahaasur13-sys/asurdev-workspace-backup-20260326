## Формулы (Swiss Ephemeris)

```python
# Расчёт Tithи
def calc_tithi(jd, sunrise):
    sun = swe.sun_utc(...)
    moon = swe.moon_utc(...)
    tithi = floor((moon - sun) / 12.0) % 30
    return tithi

# Расчёт Nakshatra
def calc_nakshatra(jd, lat, lon):
    moon = swe.calc_ut(jd, swe.MOON)
    nak = floor(moon[0] / (13 + 20/60)) % 27
    nakshatras = [
        "Ashwini", "Bharani", "Krittika", "Rohini", "Mrigashira",
        "Ardra", "Punarvasu", "Pushya", "Ashlesha", "Magha",
        "Purva Phalguni", "Uttara Phalguni", "Hasta", "Chitra",
        "Swati", "Vishaka", "Anuradha", "Jyeshtha", "Mula",
        "Purva Ashada", "Uttara Ashada", "Shravana", "Dhanishta",
        "Shatabhisha", "Purva Bhadra", "Uttara Bhadra", "Revati"
    ]
    return nakshatras[int(nak)]

# Расчёт Choghadiya
def calc_choghadiya(jd, lat, lon):
    sunrise = swe.rise_trans(jd, swe.SUN, lat, lon, flag=swe.BETH_RISET)  # восход
    day_length = (sunset - sunrise) / 8  # 8 мухурт дневных
    muhurta = floor((current_time - sunrise) / day_length) % 8

    choghadiyas = [
        "Amrit",   # 0 — лучший
        "Shubha",  # 1
        "Labh",    # 2
        "Char",    # 3
        "Samartha", # 4 — нейтральный
        "Vaidhriti", # 5
        "Rog",    # 6 — избегать
        "Kaal",   # 7 — избегать
        "Udik",   # цикл повторяется
    ]
    return choghadiyas[muhurta]
```

