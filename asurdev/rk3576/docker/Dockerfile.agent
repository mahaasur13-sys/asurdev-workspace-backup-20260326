# Dockerfile for AstroFin Agents on RK3576
# Optimized for ARM64 + NPU
FROM ubuntu:22.04

LABEL maintainer="asurdev@zo.computer"
LABEL description="AstroFin Sentinel Agent - Lightweight LLM"

# Environment
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Dubai
ENV OLLAMA_HOST=0.0.0.0:11434
ENV OLLAMA_PORT=11434
ENV OLLAMA_MODEL=gemma:2b

# Install dependencies
RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    jq \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

# Copy agent code
WORKDIR /app
COPY . /app/

# Expose Ollama port
EXPOSE 11434

# Health check
HEALTHCHECK --interval=60s --timeout=30s --start-period=300s --retries=3 \
    CMD curl -f http://localhost:11434/api/tags || exit 1

# Start Ollama server
CMD ["sh", "-c", "ollama serve & sleep 5 && o Pull ${OLLAMA_MODEL} && tail -f /dev/null"]
